# EditorConfig configuration for the NeuronPrompter workspace.
# Consistent with rustfmt.toml (tab_spaces = 4, max_width = 100).
# See https://editorconfig.org for supported editors and plugins.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.toml]
indent_size = 4

[*.json]
indent_size = 2

[Makefile]
indent_style = tab
